<?php
// Шаблон env.php. Скопировать в env.php и заполнить.
// env.php в git не попадает; на проде лежит в корне www-приложения.
// Прямой HTTP к нему отдаёт пустой ответ (нет echo/print), это защита.
//
// На новом хостинге проще всего открыть init.php — он сам определит host-пути
// и запишет валидный env.php; останется только B24_CLIENT_ID/SECRET вписать.
declare(strict_types=1);

// ── Bitrix24 (local-app) ──────────────────────────────────────────
// Создать: Разработчикам → Другое → Локальное приложение в Б24-портале.
// Скоупы — какие реально нужны проекту. Минимум для шаблона: crm, user, placement.
// Если работаешь с UF полями/смарт-процессами — добавь userfieldconfig.
// Если работаешь со списками — добавь lists.
define('B24_CLIENT_ID',     'local.XXXXXXXXXXXXXXXX.XXXXXXXX');
define('B24_CLIENT_SECRET', '');

// ── Хост приложения ──────────────────────────────────────────────
// Автоопределяются при первом запуске init.php.
define('APP_URL',  '');
define('APP_PATH', '');
define('DATA_ROOT', '');

// ── Производные file-path константы ──────────────────────────────
define('B24_TOKENS_FILE', DATA_ROOT . '/b24-tokens.php');
define('SETTINGS_FILE',   DATA_ROOT . '/settings.php');
define('SESSIONS_FILE',   DATA_ROOT . '/sessions.php');
define('STATE_FILE',      DATA_ROOT . '/state.php');
